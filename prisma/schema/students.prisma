model Student {
    id             Int       @id @default(autoincrement())
    firstName      String
    lastName       String
    age            Int?
    birthDate      DateTime? @db.Date
    url            String?
    editToken      String @unique @default(uuid()) @db.Uuid
    dataActual       Boolean   @default(false)
    dataActualizedAt DateTime?
    lessonsBalance   Int       @default(0)
    totalLessons   Int       @default(0)
    totalPayments  Int       @default(0)
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    // Relations
    organizationId Int
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    account StudentAccount?

    cart                  Cart?
    attendances           Attendance[]
    orders                Order[]
    payments              Payment[]
    groups                StudentGroup[]
    unprocessedPayments   UnprocessedPayment[]
    lessonsBalanceHistory StudentLessonsBalanceHistory[]
    wallets               Wallet[]
    parents               StudentParent[]

    @@index([organizationId])
}

model Parent {
    id          Int      @id @default(autoincrement())
    firstName   String
    lastName    String?
    phone       String?
    email       String?
    accessToken String   @unique @default(uuid()) @db.Uuid
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    organizationId Int
    organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    students       StudentParent[]

    @@index([organizationId])
}

model StudentParent {
    createdAt DateTime @default(now())

    // Relations
    studentId Int
    parentId  Int
    student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
    parent    Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)

    @@id([studentId, parentId])
    @@index([parentId])
}

model StudentAccount {
    id       Int    @id @default(autoincrement())
    login    String
    password String
    coins    Int    @default(0)

    studentId Int     @unique
    student   Student @relation(fields: [studentId], references: [id])
}

model Wallet {
    id             Int      @id @default(autoincrement())
    name           String?
    lessonsBalance Int          @default(0)
    totalLessons   Int          @default(0)
    totalPayments  Int          @default(0)
    status         WalletStatus @default(ACTIVE)
    archivedAt     DateTime?
    createdAt      DateTime     @default(now())
    updatedAt      DateTime     @updatedAt

    // Relations
    organizationId Int
    studentId      Int
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

    studentGroups  StudentGroup[]
    payments       Payment[]
    balanceHistory StudentLessonsBalanceHistory[]

    @@index([organizationId])
    @@index([studentId])
}
