# Auth
BETTER_AUTH_SECRET="supersecretkey"
BETTER_AUTH_URL='http://.test:3000'

# Frontend
NEXT_PUBLIC_ROOT_DOMAIN="dashboard.test:3000"

# Database
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/postgres?schema=public"

# Server
PORT=3000
TZ=UTC

# Image
IMAGE_URL="http://localhost:3000"
IMAGE_PATH="/uploads"

# AI Assistant (OpenRouter)
OPENROUTER_API_KEY=""
ASSISTANT_MODEL="openai/gpt-4o-mini"

# Demo mode
# DEMO_ENABLED="false" — полностью выключить вход в демо (по умолчанию включён)
DEMO_ENABLED="true"
# Пароли demo-пользователей (демо публичное, значения условны)
DEMO_OWNER_PASSWORD="demo1234"
DEMO_MANAGER_PASSWORD="demo1234"
DEMO_TEACHER_PASSWORD="demo1234"
